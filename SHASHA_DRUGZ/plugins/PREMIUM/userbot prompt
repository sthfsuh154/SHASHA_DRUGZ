# SHASHA USER CONTROL MODULE (MAIN BOT)

import time

import asyncio

import random

from SHASHA_DRUGZ import app

from pyrogram import filters

from pyrogram.types import Message, InlineKeyboardMarkup, InlineKeyboardButton

from pyrogram.errors import FloodWait

import motor.motor_asyncio

from config import MONGO_DB_URI, BOT_USERNAME

# ---------------- DATABASE ---------------- #

mongo = motor.motor_asyncio.AsyncIOMotorClient(MONGO_DB_URI)

db = mongo["SHASHA_USER_SYSTEM"]

def user_db(uid):

    return db[f"user_{uid}"]

async def get_data(uid, key, default=None):

    data = await user_db(uid).find_one({"_id": key})

    return data["value"] if data else default

async def set_data(uid, key, value):

    await user_db(uid).update_one(

        {"_id": key}, {"$set": {"value": value}}, upsert=True

    )

# ---------------- USER SESSION ---------------- #

@app.on_message(filters.command("usersession"))

async def usersession(_, m: Message):

    kb = InlineKeyboardMarkup([

        [InlineKeyboardButton("➕ Generate Session", url=f"https://t.me/{BOT_USERNAME}?start=session")]

    ])

    await m.reply(

        "**Send your session string or use button below 👇**",

        reply_markup=kb

    )

# ---------------- PING ---------------- #

@app.on_message(filters.command("ping"))

async def ping(_, m: Message):

    start = time.time()

    msg = await m.reply("🏓 Pinging...")

    end = time.time()

    await msg.edit(f"⚡ {round((end-start)*1000,2)} ms")

# ---------------- AFK ---------------- #

@app.on_message(filters.command("afk"))

async def afk(_, m: Message):

    uid = m.from_user.id

    reason = m.text.split(None, 1)[1] if len(m.command) > 1 else "AFK"

    await set_data(uid, "afk", {"reason": reason, "time": time.time()})

    await m.reply(f"🛌 AFK set: {reason}")

@app.on_message(filters.group)

async def afk_reply(_, m: Message):

    if not m.from_user:

        return

    if m.reply_to_message:

        target = m.reply_to_message.from_user.id

        afk = await get_data(target, "afk")

        if afk:

            await m.reply(f"🛌 User is AFK\nReason: {afk['reason']}")

# ---------------- PM GUARD ---------------- #

@app.on_message(filters.private & ~filters.bot)

async def pmguard(_, m: Message):

    uid = m.from_user.id

    pmguard = await get_data(uid, "pmguard", False)

    if not pmguard:

        return

    warns = await get_data(uid, f"warn_{m.from_user.id}", 0) + 1

    limit = await get_data(uid, "warn_limit", 3)

    await set_data(uid, f"warn_{m.from_user.id}", warns)

    if warns >= limit:

        await m.reply("🚫 You are blocked!")

        await app.block_user(m.from_user.id)

    else:

        await m.reply(f"⚠️ Warning {warns}/{limit}")

@app.on_message(filters.command("pmguard"))

async def toggle_pmguard(_, m: Message):

    uid = m.from_user.id

    state = m.command[1].lower()

    await set_data(uid, "pmguard", state == "on")

    await m.reply(f"PMGuard {'ON' if state=='on' else 'OFF'}")

# ---------------- ADMIN ---------------- #

@app.on_message(filters.command(["ban","kick","mute","unmute"]) & filters.group)

async def admin(_, m: Message):

    if not m.reply_to_message:

        return await m.reply("Reply to user")

    user = m.reply_to_message.from_user.id

    cmd = m.command[0]

    try:

        if cmd == "ban":

            await app.ban_chat_member(m.chat.id, user)

        elif cmd == "kick":

            await app.ban_chat_member(m.chat.id, user)

            await app.unban_chat_member(m.chat.id, user)

        elif cmd == "mute":

            await app.restrict_chat_member(m.chat.id, user, permissions={})

        elif cmd == "unmute":

            await app.unban_chat_member(m.chat.id, user)

        await m.reply(f"✅ {cmd} done")

    except Exception as e:

        await m.reply(str(e))

# ---------------- ID INFO ---------------- #

@app.on_message(filters.command("id"))

async def id(_, m: Message):

    await m.reply(f"🆔 `{m.chat.id}`")

@app.on_message(filters.command("info"))

async def info(_, m: Message):

    user = m.reply_to_message.from_user if m.reply_to_message else m.from_user

    await m.reply(f"👤 {user.first_name}\n🆔 `{user.id}`")

# ---------------- BROADCAST ---------------- #

@app.on_message(filters.command("broadcast"))

async def broadcast(_, m: Message):

    if not m.reply_to_message:

        return await m.reply("Reply to message")

    chats = []

    async for d in app.get_dialogs():

        chats.append(d.chat.id)

    sent = 0

    for chat in chats:

        try:

            await m.reply_to_message.copy(chat)

            sent += 1

        except FloodWait as e:

            await asyncio.sleep(e.value)

    await m.reply(f"📢 Sent to {sent} chats")

# ---------------- TAG ALL ---------------- #

@app.on_message(filters.command("tagall") & filters.group)

async def tagall(_, m: Message):

    members = []

    async for u in app.get_chat_members(m.chat.id):

        members.append(u.user)

    text = " ".join([f"[{u.first_name}](tg://user?id={u.id})" for u in members[:50]])

    await m.reply(text)

# ---------------- LOGGER ---------------- #

@app.on_message(filters.command("loggerid"))

async def logger(_, m: Message):

    uid = m.from_user.id

    await set_data(uid, "logger", m.chat.id)

    await m.reply("✅ Logger saved")

# ---------------- BIO ---------------- #

@app.on_message(filters.command("setbio"))

async def setbio(_, m: Message):

    return await m.reply("❌ Bots can't change bio (userbot needed)")

# ---------------- EVAL ---------------- #

@app.on_message(filters.command("eval"))

async def eval_code(_, m: Message):

    try:

        code = m.text.split(None, 1)[1]

        result = eval(code)

        await m.reply(str(result))

    except Exception as e:

        await m.reply(str(e))



