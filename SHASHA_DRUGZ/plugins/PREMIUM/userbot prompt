# SHASHA HYBRID SYSTEM (BOT + USERBOT)

import asyncio

import time

import motor.motor_asyncio

from pyrogram import Client, filters

from pyrogram.types import Message, InlineKeyboardMarkup, InlineKeyboardButton

from pyrogram.errors import FloodWait

from SHASHA_DRUGZ import app

from config import MONGO_DB_URI, API_ID, API_HASH

# ---------------- DATABASE ---------------- #

mongo = motor.motor_asyncio.AsyncIOMotorClient(MONGO_DB_URI)

db = mongo["SHASHA_HYBRID"]

def user_db(uid):

    return db[f"user_{uid}"]

async def set_session(uid, session):

    await user_db(uid).update_one(

        {"_id": "session"}, {"$set": {"value": session}}, upsert=True

    )

async def get_session(uid):

    data = await user_db(uid).find_one({"_id": "session"})

    return data["value"] if data else None

# ---------------- SESSION LOADER ---------------- #

async def get_userbot(uid):

    session = await get_session(uid)

    if not session:

        return None

    try:

        userbot = Client(

            name=f"user_{uid}",

            session_string=session,

            api_id=API_ID,

            api_hash=API_HASH,

            in_memory=True

        )

        await userbot.start()

        return userbot

    except Exception:

        return None

# ---------------- USERSSESSION ---------------- #

@app.on_message(filters.command("usersession"))

async def usersession(_, m: Message):

    kb = InlineKeyboardMarkup([

        [InlineKeyboardButton("📥 Send Session", callback_data="get_session")]

    ])

    await m.reply("**Send your session string now**", reply_markup=kb)

@app.on_message(filters.private & filters.text)

async def save_session(_, m: Message):

    if len(m.text) < 50:

        return

    uid = m.from_user.id

    await set_session(uid, m.text)

    await m.reply("✅ Session saved successfully!")

# ---------------- PING ---------------- #

@app.on_message(filters.command("ping"))

async def ping(_, m: Message):

    start = time.time()

    msg = await m.reply("🏓...")

    end = time.time()

    await msg.edit(f"⚡ {(end-start)*1000:.2f} ms")

# ---------------- USERBOT BAN ---------------- #

@app.on_message(filters.command("ban") & filters.group)

async def userban(_, m: Message):

    if not m.reply_to_message:

        return await m.reply("Reply to user")

    uid = m.from_user.id

    userbot = await get_userbot(uid)

    if not userbot:

        return await m.reply("❌ Set session first using /usersession")

    target = m.reply_to_message.from_user.id

    try:

        await userbot.ban_chat_member(m.chat.id, target)

        await m.reply("✅ Banned using userbot")

    except Exception as e:

        await m.reply(str(e))

    await userbot.stop()

# ---------------- USERBOT MUTE ---------------- #

@app.on_message(filters.command("mute") & filters.group)

async def usermute(_, m: Message):

    if not m.reply_to_message:

        return await m.reply("Reply to user")

    uid = m.from_user.id

    userbot = await get_userbot(uid)

    if not userbot:

        return await m.reply("❌ Set session first")

    target = m.reply_to_message.from_user.id

    try:

        await userbot.restrict_chat_member(m.chat.id, target, permissions={})

        await m.reply("🔇 Muted (userbot)")

    except Exception as e:

        await m.reply(str(e))

    await userbot.stop()

# ---------------- AFK (USERBOT BASED) ---------------- #

@app.on_message(filters.command("afk"))

async def afk(_, m: Message):

    uid = m.from_user.id

    reason = m.text.split(None, 1)[1] if len(m.command) > 1 else "AFK"

    await user_db(uid).update_one(

        {"_id": "afk"},

        {"$set": {"reason": reason, "time": time.time()}},

        upsert=True

    )

    await m.reply(f"🛌 AFK set: {reason}")

@app.on_message(filters.group)

async def afk_reply(_, m: Message):

    if not m.reply_to_message:

        return

    target = m.reply_to_message.from_user.id

    data = await user_db(target).find_one({"_id": "afk"})

    if data:

        await m.reply(f"🛌 AFK: {data['reason']}")

# ---------------- BROADCAST (USERBOT) ---------------- #

@app.on_message(filters.command("broadcast"))

async def broadcast(_, m: Message):

    uid = m.from_user.id

    userbot = await get_userbot(uid)

    if not userbot:

        return await m.reply("❌ No session")

    if not m.reply_to_message:

        return await m.reply("Reply to message")

    sent = 0

    async for d in userbot.get_dialogs():

        try:

            await m.reply_to_message.copy(d.chat.id)

            sent += 1

        except FloodWait as e:

            await asyncio.sleep(e.value)

    await m.reply(f"📢 Sent to {sent} chats")

    await userbot.stop()

# ---------------- EVAL ---------------- #

@app.on_message(filters.command("eval"))

async def eval_code(_, m: Message):

    try:

        code = m.text.split(None, 1)[1]

        result = eval(code)

        await m.reply(str(result))

