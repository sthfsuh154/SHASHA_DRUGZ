@Client.on_message(filters.command("a") & is_authorized)
async def approve_cmd(client: Client, message: Message):
    if not message.reply_to_message:
        return await message.edit("⚠️ Reply to a user to approve them.")
    
    user_id = message.reply_to_message.from_user.id
    user_name = message.reply_to_message.from_user.first_name
    
    await approve_user(user_id)
    # Remove warns if any
    if user_id in warns_cache:
        del warns_cache[user_id]
        
    await message.edit(f"✅ <b>{user_name}</b> has been approved to PM.")

