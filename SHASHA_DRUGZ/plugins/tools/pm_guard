# ---------------- DATABASE HELPERS ---------------- #

mongo = AsyncIOMotorClient(MONGO_DB_URI)
db = mongo["PMSecurityDB"]
approved_col = db["approved"]
settings_col = db["settings"]

# Cache to reduce DB calls
approved_cache = set()
warns_cache = {}

async def get_settings():
    data = await settings_col.find_one({"_id": "main_config"})
    if not data:
        return {
            "limit": DEFAULT_LIMIT,
            "pm_msg": DEFAULT_PM_MSG,
            "block_msg": DEFAULT_BLOCK_MSG,
            "pm_img": None,
            "img_enabled": False
        }
    return data

async def update_setting(key, value):
    await settings_col.update_one(
        {"_id": "main_config"},
        {"$set": {key: value}},
        upsert=True
    )

async def is_approved(user_id):
    if user_id in approved_cache or user_id in ADMINS:
        return True
    user = await approved_col.find_one({"user_id": user_id})
    if user:
        approved_cache.add(user_id)
        return True
    return False

async def approve_user(user_id):
    approved_cache.add(user_id)
    await approved_col.update_one(
        {"user_id": user_id},
        {"$set": {"user_id": user_id}},
        upsert=True
    )

async def disapprove_user(user_id):
    if user_id in approved_cache:
        approved_cache.remove(user_id)
    await approved_col.delete_one({"user_id": user_id})

