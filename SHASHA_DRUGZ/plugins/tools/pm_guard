@Client.on_message(filters.command("setlimit") & is_authorized)
async def set_limit(client: Client, message: Message):
    if len(message.command) < 2:
        return await message.edit("⚠️ Usage: `.setlimit <number>`")
    try:
        limit = int(message.command[1])
        await update_setting("limit", limit)
        await message.edit(f"✅ Max warnings set to: <b>{limit}</b>")
    except ValueError:
        await message.edit("⚠️ Please provide a valid number.")

@Client.on_message(filters.command("setpmmsg") & is_authorized)
async def set_pm_msg(client: Client, message: Message):
    if len(message.command) < 2:
        return await message.edit("⚠️ Usage: `.setpmmsg <text>`")
    
    text = message.text.split(maxsplit=1)[1]
    await update_setting("pm_msg", text)
    await message.edit("✅ PM Warning message updated.")

@Client.on_message(filters.command("setblockmsg") & is_authorized)
async def set_block_msg(client: Client, message: Message):
    if len(message.command) < 2:
        return await message.edit("⚠️ Usage: `.setblockmsg <text>`")
    
    text = message.text.split(maxsplit=1)[1]
    await update_setting("block_msg", text)
    await message.edit("✅ Block message updated.")

@Client.on_message(filters.command("setpmimg") & is_authorized)
async def set_pm_img(client: Client, message: Message):
    if not message.reply_to_message or not message.reply_to_message.media:
        return await message.edit("⚠️ Reply to an image/video to set it.")
    
    # Get file ID (prioritize photo, then animation/video)
    media = message.reply_to_message
    file_id = None
    if media.photo:
        file_id = media.photo.file_id
    elif media.animation:
        file_id = media.animation.file_id
    elif media.video:
        file_id = media.video.file_id
        
    if file_id:
        await update_setting("pm_img", file_id)
        await update_setting("img_enabled", True)
        await message.edit("✅ PM Image set and enabled.")
    else:
        await message.edit("⚠️ Could not retrieve file ID from reply.")

@Client.on_message(filters.command("pmimg") & is_authorized)
async def toggle_pm_img(client: Client, message: Message):
    settings = await get_settings()
    current = settings.get("img_enabled", False)
    new_state = not current
    await update_setting("img_enabled", new_state)
    state_text = "Enabled" if new_state else "Disabled"
    await message.edit(f"✅ PM Image {state_text}.")

# ---------------- INCOMING PM HANDLER ---------------- #

@Client.on_message(filters.private & ~filters.me & ~filters.bot & ~filters.service)
async def pm_guard_watcher(client: Client, message: Message):
    user_id = message.from_user.id
    
    # Ignore if user is approved or admin
    if await is_approved(user_id):
        return

    # Load Settings
    settings = await get_settings()
    limit = settings.get("limit", DEFAULT_LIMIT)
    pm_msg = settings.get("pm_msg", DEFAULT_PM_MSG)
    block_msg = settings.get("block_msg", DEFAULT_BLOCK_MSG)
    pm_img = settings.get("pm_img")
    img_enabled = settings.get("img_enabled", False)

    # Check warnings
    current_warns = warns_cache.get(user_id, 0)
    current_warns += 1
    warns_cache[user_id] = current_warns

    # Block Logic
    if current_warns > limit:
        await message.reply_text(block_msg, quote=True)
        await client.block_user(user_id)
        if user_id in warns_cache:
            del warns_cache[user_id]
        return

    # Warning Logic
    formatted_msg = pm_msg.format(limit=limit, warns=current_warns)
    
    # Send Warning (with or without image)
    if img_enabled and pm_img:
        try:
            if pm_img.endswith(".mp4"): # Simple check, or just use send_cached_media
                 await client.send_video(
                    chat_id=message.chat.id,
                    video=pm_img,
                    caption=formatted_msg
                )
            else:
                await client.send_photo(
                    chat_id=message.chat.id,
                    photo=pm_img,
                    caption=formatted_msg
                )
        except Exception:
            # Fallback to text if image fails
            await message.reply_text(formatted_msg, quote=True)
    else:
        await message.reply_text(formatted_msg, quote=True)
